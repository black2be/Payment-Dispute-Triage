{
  "name": "Run tests on change",
  "description": "Run the related Vitest suite when domain logic or a test file changes.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/engine/**/*.ts",
      "src/data/**/*.ts",
      "tests/**/*.test.{ts,tsx}"
    ]
  },
  "then": {
    "type": "agentExecution",
    "prompt": "Run the Vitest tests relevant to #file (the matching *.test.ts and any suite that imports it). Report pass/fail with the failing assertions. If the rules engine changed, confirm the worked-example table (design §3.5 cases A–G) and properties P1–P7 still pass. Do not mark the related task done unless the suite is green (gov-post-task-test)."
  }
}
