{
  "name": "Type-check on save",
  "description": "Run TypeScript strict type-check on the saved file's project.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": ["src/**/*.ts", "src/**/*.tsx"]
  },
  "then": {
    "type": "agentExecution",
    "prompt": "Run `tsc --noEmit` (strict) for the project. Report any type errors with file and line. Fix by tightening types, never by adding `any` or `@ts-ignore`. Enum/string-union values must match the spec verbatim."
  }
}
