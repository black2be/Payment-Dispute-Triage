# Caddy edge: terminates TLS (auto Let's Encrypt when DOMAIN is a real host)
# and routes traffic to the two app containers on the internal network.
#
#   /api/*  -> api:3001   (Express)
#   /*      -> client:80  (nginx static SPA)

{$DOMAIN:localhost} {
	encode gzip

	# API → Node/Express (path is preserved; server mounts under /api)
	@api path /api/*
	reverse_proxy @api api:3001

	# Everything else → nginx serving the React build
	reverse_proxy client:80
}
